# ContractGate — environment variables
# Copy to .env and fill in your values

# PostgreSQL connection string (Supabase)
DATABASE_URL=postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres

# Server port (default: 3001)
PORT=3001

# Log level: trace | debug | info | warn | error
RUST_LOG=contractgate=debug,tower_http=info

# Auth (RFC-066): the authenticated surface accepts Supabase JWTs (dashboard)
# and DB-backed API keys (issued via POST /api/keys). There is no env-var
# master key. For LOCAL DEV ONLY, set the line below to run with no auth.
# Never set this in production.
# CONTRACTGATE_DEV_NO_AUTH=1

# Optional: downstream webhook for forwarding validated events
# FORWARD_WEBHOOK_URL=https://your-service.example.com/events

# Optional: explicit Supabase project URL for JWKS lookup.
# Set this if DATABASE_URL is a pooler URL (aws-0-*.pooler.supabase.com)
# and JWKS auto-derivation fails at startup (symptom: "JWKS not loaded —
# Bearer JWT auth disabled" in logs).
# Example: SUPABASE_URL=https://abcdefghijklmnopqrst.supabase.co
# SUPABASE_URL=

# CORS origin allowlist for the authenticated API surface (RFC-050).
# Comma-separated list of allowed origins for the dashboard and API clients.
# Unset → defaults to http://localhost:3000 with a startup warning.
# In production: fly secrets set DASHBOARD_ORIGIN=https://app.datacontractgate.com
# DASHBOARD_ORIGIN=https://app.datacontractgate.com

# ── Slack Bot (RFC-084) ────────────────────────────────────────────────────────
# See docs/slack-bot-setup.md for step-by-step instructions.

# Bot User OAuth Token — from your Slack app's "OAuth & Permissions" page.
# Starts with xoxb-
SLACK_BOT_TOKEN=xoxb-...

# Signing Secret — from your Slack app's "Basic Information" page.
# Used to verify that incoming requests genuinely come from Slack (HMAC-SHA256).
SLACK_SIGNING_SECRET=

# Shared secret for the POST /api/slack/announce endpoint.
# Generate with: openssl rand -hex 32
# Pass as: Authorization: Bearer <secret>
SLACK_ANNOUNCE_SECRET=

# ── AI (used by Slack bot and any future AI features) ─────────────────────────
# Which backend answers general Slack Q&A: xai | anthropic (default anthropic)
LLM_PROVIDER=xai

# xAI — required when LLM_PROVIDER=xai (https://console.x.ai/)
XAI_API_KEY=
# Optional; default grok-4
# XAI_MODEL=grok-4

# Anthropic — required when LLM_PROVIDER=anthropic (https://console.anthropic.com/)
ANTHROPIC_API_KEY=
# Optional; default claude-sonnet-4-6
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Slack bot LLM abuse caps (defaults in code if unset)
# SLACK_LLM_PER_USER_HOUR=10
# SLACK_LLM_PER_USER_DAY=30
# SLACK_LLM_PER_THREAD=12
# SLACK_LLM_MAX_TOKENS=512
# SLACK_LLM_HISTORY_LIMIT=8
# Comma-separated Slack team IDs; empty = any workspace where the app is installed
# SLACK_ALLOWED_TEAM_IDS=T01234567