# RFC-088 internal admin app — server-only secrets. NEVER prefix with NEXT_PUBLIC_.
# Set these in Vercel project settings, not in the repo.

# Supabase project URL (also used to derive the dashboard project ref for links).
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Service-role key — bypasses RLS. God-mode reads. Server only.
SUPABASE_SERVICE_ROLE_KEY=

# Anon key — used ONLY for the login form's password auth (not privileged).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Stripe secret key (sk_live_... or sk_test_...). Server only.
STRIPE_SECRET_KEY=

# Comma-separated superadmin allowlist. Only these emails may sign in.
ADMIN_EMAILS=you@yourdomain.com

# Supabase project ref for building Supabase dashboard deep links (e.g. abcd1234).
SUPABASE_PROJECT_REF=YOUR_PROJECT_REF
