{
  "type": "record",
  "name": "Order",
  "namespace": "com.contractgate.demo",
  "fields": [
    {"name": "order_id",    "type": "string"},
    {"name": "customer_id", "type": "string"},
    {"name": "email",       "type": ["null", "string"], "default": null},
    {"name": "amount",      "type": "double"},
    {"name": "currency",    "type": "string"},
    {"name": "created_at",  "type": "long"}
  ]
}
