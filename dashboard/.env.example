# Copy this to .env.local and fill in real values.
# Never commit real secrets.

# Existing (Supabase + API)
NEXT_PUBLIC_API_URL=https://contractgate-api.fly.dev
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# === STRIPE (for ContractGate SaaS payments) ===
# Use the keys + prices from the *ContractGate* Stripe account
# (the separate account under your NightMoose Organization).
# See datacontractgate_website/stripe-integration.md and the org/account setup notes.

# Secret key (sk_live_... or sk_test_... for dev)
STRIPE_SECRET_KEY=sk_test_***

# Webhook signing secret (whsec_... from the webhook endpoint you create in the ContractGate Stripe account)
STRIPE_WEBHOOK_SECRET=whsec_***

# Price IDs for the Growth plans (from the Products you created in Stripe Dashboard)
# IMPORTANT: These are the "price_1..." IDs, NOT the buy.stripe.com Payment Links.
# Go to Products → click the Growth product → click each price → copy the price ID.
# These are used by the in-app upgrade flow (/api/stripe/create-checkout-session).
# The marketing site uses separate Payment Link URLs (set in datacontractgate_website/index.html).
STRIPE_PRICE_GROWTH_MONTHLY=price_***
STRIPE_PRICE_GROWTH_ANNUAL=price_***

# Your app base URL for success/cancel/portal redirects (no trailing slash)
NEXT_PUBLIC_APP_URL=https://app.datacontractgate.com

# Optional: Resend for emails (already in use for early access etc.)
RESEND_API_KEY=re_...

# Cloudflare Turnstile (bot-protection CAPTCHA on signup)
# Get keys at https://dash.cloudflare.com -> Turnstile -> Add site
# Dev placeholder below is Cloudflare's "always passes" test key.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
